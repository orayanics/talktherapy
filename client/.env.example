VITE_STAGE=production
VITE_SERVER_PORT=8080
VITE_APP_API_URL=https://0.0.0.0:8080
VITE_APP_WSS_URL=wss://0.0.0.0:8080

# Better-Auth
BETTER_AUTH_SECRET=
