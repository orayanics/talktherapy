// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output = "./generated"
    engineType = "client"
    runtime = "bun"
}

datasource db {
  provider = "sqlite"
}

model Permissions {
  id         String   @id @default(uuid())
  name       String   @unique
  created_at DateTime @default(now())
}

model Diagnosis {
  id         String   @id @default(uuid())
  value      String   @unique
  label      String      @unique
  created_at DateTime @default(now())

  patient Patient[]
  clinician Clinician[]
  content Content[]
}

model User {
  id              String   @id @default(uuid())
  name            String?  @default("")
  email           String   @unique
  password        String?
  account_status  String   @default("active")
  account_role    String?
  account_permissions String @default("")

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  created_by      String?
  updated_by      String?
  deleted_at      DateTime?

  sudo      Sudo?
  admin     Admin?
  patient   Patient?
  clinician Clinician?
  refresh_tokens RefreshToken[]
  content Content[]
}

model Sudo {
  id        String   @id @default(uuid())
  user_id   String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Admin {
  id       String   @id @default(uuid())
  user_id   String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Patient {
  id          String   @id @default(uuid())
  user_id     String   @unique
  diagnosis_id String?
  consent     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  diagnosis Diagnosis? @relation(fields: [diagnosis_id], references: [id], onDelete: SetNull)
}

model Clinician {
  id          String   @id @default(uuid())
  user_id     String   @unique
  diagnosis_id String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  diagnosis Diagnosis? @relation(fields: [diagnosis_id], references: [id], onDelete: SetNull)
  slots Slot[]
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Otps {
  id        String   @id @default(uuid())
  user_id  String 
  otp_code String
  purpose String
  expires_at DateTime
  created_at DateTime @default(now())
}

model AvailabilityRule {
  id        String   @id @default(uuid())
  clinician_id String

  starts_at DateTime
  ends_at DateTime

  recurrence_rule String? // RFC5545 RRULE string e.g. "FREQ=WEEKLY;BYDAY=MO,WE,FR"
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  slots Slot[] 
}

model Appointments {
  id String  @id @default(uuid())

  slot_id String
  patient_id String

  status AppointmentStatus @default(PENDING)

  booked_at DateTime @default(now())
  confirmed_at DateTime?
  cancelled_at DateTime?
  completed_at DateTime?
  rescheduled_at DateTime?

  room_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  slot Slot @relation(fields: [slot_id], references: [id])
  events      AppointmentEvent[]
  encounter   Encounter?
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  CANCELLED
  COMPLETED
}

model Slot {
  id String  @id @default(uuid())
  availability_rule_id String
  clinician_id String

  starts_at DateTime
  ends_at DateTime

  status SlotStatus @default(AVAILABLE)

  appointments Appointments[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinician Clinician @relation(fields: [clinician_id], references: [id], onDelete: Cascade)
  availability_rule AvailabilityRule @relation(fields: [availability_rule_id], references: [id], onDelete: Cascade)
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentEventType {
  BOOKED
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum ActorType {
  PATIENT
  CLINICIAN
  SYSTEM
  ADMIN
}

model AppointmentEvent {
  id String @id @default(uuid())
  appointment_id String

  type AppointmentEventType
  actor_type ActorType
  actor_id String

  reason String?

  created_at DateTime @default(now())

  appointment Appointments @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
} 

model Encounter {
  id             String   @id @default(uuid())
  appointment_id String   @unique

  diagnosis      String
  chief_complaint String
  referral_source String
  referral_url    String

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  appointment    Appointments @relation(fields: [appointment_id], references: [id])
}

// Content Models
model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  slug     String       @unique

  contents ContentTag[]
}

model ContentTag {
  content_id String
  tag_id     String

  content Content @relation(fields: [content_id], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([content_id, tag_id])
}

model Content {
  id          String   @id @default(uuid())
  author_id   String
  diagnosis_id String

  title       String
  description String
  body        String   // @db.Text for postgres/mysql

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author   User        @relation(fields: [author_id], references: [id], onDelete: Cascade)
  diagnosis Diagnosis   @relation(fields: [diagnosis_id], references: [id], onDelete: Restrict)
  tags     ContentTag[]
}