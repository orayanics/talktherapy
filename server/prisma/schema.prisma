// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../src/generated/prismabox"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  superadmin
  admin
  clinician
  patient
}

enum AccountStatus {
  pending
  active
  suspended
  inactive
}

enum SlotStatus {
  FREE
  PENDING
  ACCEPTED
  REJECT
  CANCELLED
  COMPLETED
}

enum AppointmentStatus {
  PENDING
  ACCEPTED
  REJECT
  CANCELLED
  COMPLETED
}

enum AppointmentEventType {
  STATUS_CHANGE
}

enum ActorType {
  patient
  clinician
}

model Diagnosis {
  id          String   @id
  label       String   @unique
  value       String   @unique
  createdAt   DateTime @default(now())

  users User[]
  diagnosisContents Content[]
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  role       Role 
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  status AccountStatus @default(pending)
  diagnosis_id String?

  diagnosis Diagnosis? @relation(fields: [diagnosis_id], references: [id], onDelete: SetNull)
  contents  Content[]
  bookmarks Bookmark[]
  tags      Tag[]
  auditLogs AuditLog[] @relation("UserAuditLogs")
  patientAppointments Appointment[] @relation("PatientAppointments")
  clinicianAppointments Appointment[] @relation("ClinicianAppointments")
  availabilityRules AvailabilityRule[] @relation("AvailabilityClinician")
  clinicianPatients ClinicianPatient[] @relation("ClinicianPatients")
  patientClinicians ClinicianPatient[] @relation("PatientClinicians")
  slots Slot[] @relation("UserSlots")
  soaps Soap[] @relation("SoapClinician")
  soapsAsPatient Soap[] @relation("SoapPatient")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Content {
  id          String   @id @default(uuid())
  authorId    String
  diagnosisId String?
  title       String
  description String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  diagnosis Diagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags      Tag[]
  bookmarks Bookmark[]
}

model Tag {
  id       String @id @default(cuid())
  name     String
  slug     String

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  contents Content[]

  @@unique([authorId, slug])
  @@index([authorId])
}
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
}

model AuditLog {
  id       String   @id @default(cuid())
  actorId   String?
  actorEmail String?
  actorRole String?
  action    String
  details   String?
  createdAt DateTime @default(now())

  // relation to user for easier querying of logs by actor
  // ooptional: decide if needs to be deleted later on
  actor User? @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: Cascade)

}

// Appointment-related models converted from Laravel Eloquent models
model Appointment {
  id           String   @id @default(uuid())
  slotId       String?
  patientId    String
  clinicianId  String?
  status       String?
  bookedAt     DateTime?
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  completedAt  DateTime?
  rescheduledAt DateTime?
  roomId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient  User     @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  clinician User?   @relation("ClinicianAppointments", fields: [clinicianId], references: [id], onDelete: SetNull)

  slot     Slot?    @relation(fields: [slotId], references: [id])
  events   AppointmentEvent[]
  encounter Encounter?

  @@index([patientId])
  @@index([clinicianId])
  @@map("appointment")
}

model AppointmentEvent {
  id            String   @id @default(uuid())
  appointmentId String
  type          String?
  actorType     String?
  actorId       String?
  reason        String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("events")
}

model AvailabilityRule {
  id             String   @id @default(uuid())
  clinicianId    String
  startAt        DateTime
  endAt          DateTime
  recurrenceRule String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinician User @relation("AvailabilityClinician", fields: [clinicianId], references: [id], onDelete: Cascade)
  slots     Slot[]

  @@index([clinicianId])
  @@map("schedules")
}

model Slot {
  id                 String   @id @default(uuid())
  availabilityRuleId String?
  clinicianId        String
  startAt            DateTime
  endAt              DateTime
  status             SlotStatus @default(FREE)
  isHidden           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  availabilityRule AvailabilityRule? @relation(fields: [availabilityRuleId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  user User @relation("UserSlots",fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([availabilityRuleId])
  @@index([clinicianId])
  @@map("slot")
}

model ClinicianPatient {
  id               String   @id @default(uuid())
  clinicianId      String
  patientId        String
  firstCompletedAt DateTime?

  clinician User @relation("ClinicianPatients", fields: [clinicianId], references: [id], onDelete: Cascade)
  patient   User @relation("PatientClinicians", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([clinicianId, patientId])
  @@map("clinician_patient")
}

model Encounter {
  id             String   @id @default(uuid())
  appointmentId  String   @unique
  diagnosis      String?
  chiefComplaint String?
  referralSource String?
  referralUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Soap {
  id             String   @id @default(uuid())
  clinicianId    String
  patientId      String
  activity_plan  String
  session_type   String?
  subjective_notes String?
  objective_notes  String?
  assessment       String?
  recommendation   String?
  comments         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinician User @relation("SoapClinician",fields: [clinicianId], references: [id])
  patient   User @relation("SoapPatient", fields: [patientId], references: [id])

  @@map("soaps")
}

