# Envinronment variables for the server
SERVER_ENV=development
SERVER_PORT=8000
CLIENT_URL=http://192.168.1.10:3000
CLIENT_URL_HTTPS=https://192.168.1.10:3000

# Extra trusted origins (comma-separated)
DEV_TRUSTED_ORIGINS=https://192.168.1.15:3000,https://0.0.0.0:3000

TLS_KEY_PATH='../certs/localhost-key.pem'
TLS_CERT_PATH='../certs/localhost.pem'

ALLOW_ANON_WS=true


# Prisma
DATABASE_URL=file:./dev.db

# Better-Auth
BETTER_AUTH_SECRET=UqikJTsh4ScQxzNzBGG9PohBGdIcbm2U # Sample secret, replace with your own in production
BETTER_AUTH_URL=http://192.168.1.10:3000 # Base URL of your app

# GMAIL SMTP
SMTP_USER= # Your Gmail email address
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD= # Use an app password for Gmail if 2FA is enabled
